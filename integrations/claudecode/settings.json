{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "tsx /path/to/parallax/integrations/claudecode/src/pre_tool_use.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "tsx /path/to/parallax/integrations/claudecode/src/post_tool_use.ts"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tsx /path/to/parallax/integrations/claudecode/src/notification.ts"
          }
        ]
      }
    ]
  }
}
